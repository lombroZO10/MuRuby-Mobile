	<!-- Yêu cầu kill boss để trờ thành guild thắng -->
	<!-- CheDo1 = sửa KillBoss = 2 -->
	<!-- CheDo2 = sửa KillBoss = 3 -->
	<!----------------------------------------------------------------------------------------------->
	<DieuKienGuildWin>
