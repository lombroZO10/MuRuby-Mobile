	<!-- Cài đặt 2 chế độ Boss -->
	<!-- CheDo1 = có 3 boss, Phù Thủy, Chiến Binh, Tiên Nữ -->
	<!-- CheDo2 = có 4 boss, Thuật Sĩ, Thiết Binh, Đấu Sĩ, Chúa Tể -->
	<!----------------------------------------------------------------------------------------------->
	<CheDoBoss>
	    <Config	CheDo1="1" CheDo2="0"/>
    </CheDoBoss>	
