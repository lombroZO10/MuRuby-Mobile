<!-- 
Fix Giật Lui Skill
Config tỷ lệ xuất hiện đẩy lùi khi dùng skill
IDSkill = Index Skill
Rate = Tỷ lệ xuất hiện giật lùi (Max 100)
Type = Loại khựng

ChainLightning = Sét liên hoàn (Sum)
Cyclone = Chém Xoáy Ngang(DK,MG)
ChainDriver = Vật Ngã (RF)
-->
	<SkillBackSpring>
	<!--Đẩy Lùi-->
        <Skill IDSkill="215" Rate="1" Type="1"/>     <!--Sét Liên Hoàn Sum-->
        <Skill IDSkill="237" Rate="1" Type="1"/>     <!--Bão Điện MG-->
		<Skill IDSkill="262" Rate="50" Type="1"/>    <!--Vật Ngã RF-->
		<Skill IDSkill="22"  Rate="1" Type="1"/>   <!--Tăng Cường Chém Xoáy Ngang DK-->

	</SkillBackSpring>
	
	<!--Choáng-->
