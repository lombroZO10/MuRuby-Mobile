	<Message Index="1" Text="[Reset]Cần có x%d (%s) để thực hiện Reset!" />
	<Message Index="2" Text="Bạn cần sử dụng Code Reset để Reset lần %d!" />
    <Message Index="3" Text="Nhân vật [%s] vừa Reset Thường lần %d thành công!" />
