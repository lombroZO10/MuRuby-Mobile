<NPC>
	<!-- PREMIUM VERSION 	-->
	<!-- Config 	-->
	<SetNPC  NPCClass="601" NPCMap="0" NPCX="130" NPCY = "121" NPCDir="3"/>
</NPC>

<MessageInfo>
	<Message Index="0" Text="[Transferencia Excellent] Voce precisa de %d WCoinC" />
	<Message Index="1" Text="[Transferencia Excellent] Voce precisa de %d WCoinP" />
	<Message Index="2" Text="[Transferencia Excellent] Voce precisa de %d Goblin Points" />
	<Message Index="3" Text="[Transferencia Excellent] Retire primeiro o item material" />
	<Message Index="4" Text="[Transferencia Excellent] Item incompativel" />
	<Message Index="5" Text="[Transferencia Excellent] Use um material permitido" />
	<Message Index="6" Text="[Transferencia Excellent] Adicione o item material" />
