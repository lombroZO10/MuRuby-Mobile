<CongHuongItem>
	<Config  Enabled = "1"/>
	<!-- Cấu hình cộng hướng		
		- CHReset : Resset > CHReset mới được CH
		- CHLuck,CHSkill,CHLevel =  1 thì sẽ cho phép cộng hướng luck,skill,level của phôi sang Item chính
		- CHCheckPhoiType 
				= 0 không check item phôi miễn là exc và cùng loại (VD Kiếm vs Kiếm)
				= 1 thì sẽ bắt buộc phôi cộng hưởng là item có cấp độ bằng hoặc cao hơn item chính (cấp độ item)
				= 2 bắt buộc phôi phải là item giống item chính (VD "Kiếm Rồng" vs "Kiếm Rồng")

		- Type là cấu hình tỷ lệ cộng hướng thành công, có thể thêm nhiều type để đặt điều kiện ở mỗi mốc lvl hoặc dòng exc
		  VD : Item chính có + Lv > LvMin && < LvMax, Số dòng Exc > ExcMin && < ExcMax thì tỷ lệ thành công = CHRate,
		- nếu cho phép CHLevel =1 thì CH thành công item sẽ cộng tối đa thêm CHLevelMax.. (VD item chính level 5 phôi 15, cộng hưởng thành công item sẽ lên level +8 (vì CHLevelMax = 3)
		  CHLevelMax = 0 thì sẽ cộng hưởng +level của phôi sang
		  WC= WCoin, WCP = WCoinP, GBP = GobinPoint
		- CHKeepItem = 1 (Giữ lại item phôi sau khi cộng hưởng)
		- CHAllowAnc = 1 Cho Phep cong huong item THan
	-->
	<CHConifg CHReset = "0" CHLuck= "1" CHSkill = "0" CHLevel="0" CHOptLife= "0"  CHCheckPhoiType= "1" CHKeepItem="1" CHAllowAnc="0" >
	
		<Type LvMin="0"  LvMax="15"  ExcMin="1" ExcMax="63" CHLevelMax = "1"  WC="10000" 	WCP="0" 	GBP="0" 	CHRate="30"/>

		
	</CHConifg>
</CongHuongItem>