		<Type ExcOpt="2" 	WC="100000" 	WCP="0" GBP="0" Rate="100" />
		<Type ExcOpt="3"	WC="100000" 	WCP="0" GBP="0" Rate="100" />
		<Type ExcOpt="4"	WC="500000" 	WCP="0" GBP="0" Rate="100" />
		<Type ExcOpt="5"	WC="100000" 	WCP="0" GBP="0" Rate="100" />
	</HuyExcConfig>
